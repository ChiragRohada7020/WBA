<!DOCTYPE html>
<html>
<head>
    <title>Edit Birthday</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        body {
            background: linear-gradient(135deg, #0f172a, #1e293b, #334155);
        }
    </style>
</head>

<body class="min-h-screen flex items-center justify-center text-gray-100 p-4">

<!-- 🔥 CARD -->
<div class="w-full max-w-lg p-8 rounded-2xl bg-white/10 backdrop-blur-lg shadow-xl">

    <!-- TITLE -->
    <h2 class="text-2xl font-bold text-center mb-6">
        ✏️ Edit Birthday
    </h2>

    <!-- FORM -->
    <form method="POST" class="space-y-5">

        <!-- NAME -->
        <div>
            <label class="text-sm text-gray-300">Name</label>
            <input 
                name="name"
                value="<%= item.name %>"
                required
                class="w-full mt-1 p-3 rounded-xl bg-white/10 border border-white/20 focus:outline-none focus:ring-2 focus:ring-blue-400"
            >
        </div>

        <!-- PHONE -->
        <div>
            <label class="text-sm text-gray-300">Phone Number</label>
            <input 
                name="number"
                value="<%= item.number %>"
                required
                class="w-full mt-1 p-3 rounded-xl bg-white/10 border border-white/20 focus:outline-none focus:ring-2 focus:ring-blue-400"
            >
        </div>

        <!-- RELATION -->
        <div>
            <label class="text-sm text-gray-300">Relation</label>
            <input 
                name="relation"
                value="<%= item.relation %>"
                placeholder="friend / family / client"
                class="w-full mt-1 p-3 rounded-xl bg-white/10 border border-white/20 focus:outline-none focus:ring-2 focus:ring-blue-400"
            >
        </div>

        <!-- DATE -->
        <div>
            <label class="text-sm text-gray-300">Date</label>
            <input 
                type="text"
                name="date"
                value="<%= item.date %>"
                required
                class="w-full mt-1 p-3 rounded-xl bg-white/10 border border-white/20 text-gray-300 focus:outline-none focus:ring-2 focus:ring-blue-400"
            >
        </div>

        <!-- JID -->
        <div>
            <label class="text-sm text-gray-300">JID</label>
            <input 
                name="jid"
                value="<%= item.jid %>"
                placeholder="WhatsApp JID"
                class="w-full mt-1 p-3 rounded-xl bg-white/10 border border-white/20 focus:outline-none focus:ring-2 focus:ring-blue-400"
            >
        </div>

        <!-- GREETING -->
        <div>
            <label class="text-sm text-gray-300">Greeting</label>
            <input 
                name="greeting"
                value="<%= item.greeting %>"
                placeholder="Custom message"
                class="w-full mt-1 p-3 rounded-xl bg-white/10 border border-white/20 focus:outline-none focus:ring-2 focus:ring-blue-400"
            >
        </div>

        <!-- ACTION BUTTONS -->
        <div class="flex flex-col sm:flex-row gap-3 mt-4">

            <!-- UPDATE -->
            <button 
                type="submit"
                class="w-full sm:w-auto bg-blue-500 hover:bg-blue-600 px-6 py-3 rounded-xl font-semibold transition shadow-md">
                Update
            </button>

        </div>

    </form>

    <!-- DELETE -->
    <form action="/delete/<%= item._id %>" method="GET"
          onsubmit="return confirm('Are you sure you want to delete?')"
          class="mt-4">

        <button 
            class="w-full border border-red-400 text-red-300 hover:bg-red-500 hover:text-white py-3 rounded-xl transition">
            🗑️ Delete
        </button>
    </form>

    <!-- BACK -->
    <a href="/" class="block text-center mt-4 text-gray-300 hover:text-white transition">
        ← Back
    </a>

</div>

</body>
</html>